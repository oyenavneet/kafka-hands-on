# Kafka is always designed to run as a cluster even if you start only one broker.
# It is a cluster with one node.

KAFKA_PROCESS_ROLES=broker,controller
KAFKA_NODE_ID=1
KAFKA_CLUSTER_ID=OTMwNzFhYTY1ODNiNGE5OT

KAFKA_LISTENERS=EXTERNAL://:9092,CONTROLLER://:9093
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_INTER_BROKER_LISTENER_NAME=EXTERNAL
KAFKA_ADVERTISED_LISTENERS=EXTERNAL://localhost:9092

KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093

KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,EXTERNAL:SASL_PLAINTEXT

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# SASL - PLAIN: Username / Password 
KAFKA_SASL_ENABLED_MECHANISMS=PLAIN
KAFKA_SASL_MECHANISM_INTER_BROKER_PROTOCOL=PLAIN